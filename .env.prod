APP_ENV=prod
APP_NAME=bAutoCV API
APP_DESCRIPTION=Backend service for CV automation workflows.
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc

DATABASE_URL=postgresql+asyncpg://user:password@host:5432/bautocv_prod
DATABASE_ECHO=false

RENDERCV_ENABLED=true
RENDERCV_BIN=rendercv
RENDERCV_OUTPUT_DIR=generated_cvs
